#!/usr/bin/env bash
# cluo :: Cluolingo control + scoreboard CLI
# Usage: cluo <command> [args]
#   stats                    show scoreboard
#   on | off                 enable / disable the companion
#   lang <language>          set the target practice language (e.g. cluo lang Japanese)
#   native <language>        set your native language (default Chinese)
#   grade correct|wrong      record an answer (called by Claude)
#   word <text>              log a newly taught vocab item (called by Claude)
#   preset chill|normal|hardcore
#   set mode every|freq|chance
#   set freq <N> | set chance <0-100>
#   reset                    reset the scoreboard (keeps settings)
set -euo pipefail

CONFIG_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
STATE_DIR="$CONFIG_DIR/cluolingo"
STATE_FILE="$STATE_DIR/state.json"

command -v jq >/dev/null 2>&1 || { echo "cluo: jq is required"; exit 1; }
mkdir -p "$STATE_DIR"
if [ ! -f "$STATE_FILE" ]; then
  cat > "$STATE_FILE" <<'JSON'
{ "enabled": true, "mode": "every", "freq": 5, "chance": 30,
  "target_lang": "English", "native_lang": "Chinese",
  "prompt_count": 0, "quiz_count": 0, "correct": 0,
  "streak": 0, "best_streak": 0, "pending": [], "words_seen": [] }
JSON
fi

_save() { # _save [jq-args...] '<filter>'  — all args forwarded to jq, then the state file
  local tmp; tmp="$(mktemp "$STATE_DIR/.state.XXXXXX")"
  jq "$@" "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

_norm() { # normalize an answer for comparison: lowercase, trim, strip surrounding punctuation
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//; s/^[^[:alnum:]]+//; s/[^[:alnum:]]+$//'
}

cmd="${1:-stats}"; shift || true
case "$cmd" in
  stats|state)
    jq -r '
      "🦉 Cluolingo — scoreboard",
      "  status   : \(if .enabled then "on" else "off" end)  (mode: \(.mode))",
      "  learning : \(.target_lang)  (from \(.native_lang))",
      "  asked    : \(.quiz_count)   correct: \(.correct)",
      "  accuracy : \(if .quiz_count>0 then ((.correct*100/.quiz_count)|floor|tostring)+"%" else "—" end)",
      "  streak   : \(.streak)   best: \(.best_streak)",
      "  words    : \(.words_seen|length) learned"
    ' "$STATE_FILE"
    ;;
  on)  _save '.enabled = true';  echo "cluolingo: on" ;;
  off) _save '.enabled = false'; echo "cluolingo: off" ;;
  lang)
    l="${*:-}"; [ -n "$l" ] || { echo "usage: cluo lang <language>  (e.g. cluo lang Japanese)"; exit 1; }
    _save --arg l "$l" '.target_lang = $l'
    echo "🎯 now practicing: $l"
    ;;
  native)
    l="${*:-}"; [ -n "$l" ] || { echo "usage: cluo native <language>"; exit 1; }
    _save --arg l "$l" '.native_lang = $l'
    echo "🏠 native language: $l"
    ;;
  grade)
    case "${1:-}" in
      correct) _save '.quiz_count+=1 | .correct+=1 | .streak+=1 | .best_streak = ([.best_streak,.streak]|max)'
               echo "✅ correct  (streak: $(jq -r .streak "$STATE_FILE"))" ;;
      wrong)   _save '.quiz_count+=1 | .streak = 0'
               echo "❌ wrong  (streak reset)" ;;
      *) echo "usage: cluo grade correct|wrong"; exit 1 ;;
    esac
    ;;
  word)
    w="${*:-}"; [ -n "$w" ] || { echo "usage: cluo word <text>"; exit 1; }
    _save --arg w "$w" '.words_seen = ((.words_seen + [$w]) | unique)'
    echo "📒 logged: $w"
    ;;
  ask)
    # Claude queues a pending question so the user can answer out-of-band.
    # pending is a QUEUE; each item is tagged with the Claude Code session id so a
    # session answers its OWN questions even when several run in parallel.
    a="${1:-}"; e="${2:-}"; q="${3:-}"
    [ -n "$a" ] || { echo "usage: cluo ask <correct_answer> [explanation] [question]"; exit 1; }
    sid="${CLAUDE_CODE_SESSION_ID:-}"
    _save --arg a "$a" --arg e "$e" --arg q "$q" --arg s "$sid" '
      .pending = (((.pending // []) | if type=="object" then [.] else . end) + [{answer:$a, explain:$e, q:$q, session:$s}])'
    # Report a PER-SESSION count + the question text. The global queue length is
    # noisy/alarming across many parallel sessions, so we don't surface it here.
    mine="$(jq --arg s "$sid" '(((.pending // []) | if type=="object" then [.] else . end))
            | map(select(($s=="") or (.session==$s) or ((.session // "")=="")))| length' "$STATE_FILE")"
    if [ -n "$sid" ]; then tag=" [sess ${sid: -4}]"; else tag=""; fi
    echo "📌 queued$tag — you now have $mine open in this session"
    [ -n "$q" ] && echo "   Q: $q"
    echo "   answer:  cluo answer <your answer>   (peek what's open: cluo answer)"
    ;;
  answer)
    sid="${CLAUDE_CODE_SESSION_ID:-}"
    u="${*:-}"
    if [ -z "$u" ]; then
      # No answer given → peek mode: show THIS session's open questions so you can
      # see exactly what you're being asked before you reply.
      jq -r --arg s "$sid" '
        (((.pending // []) | if type=="object" then [.] else . end))
        | map(select(($s=="") or (.session==$s) or ((.session // "")=="")))
        | if length==0 then "🤔 nothing pending for you right now"
          else "📋 \(length) open for you (newest last) — answer with: cluo answer <ans>",
               (to_entries[] | "   • \(.value.q // ("answer: "+.value.answer))")
          end' "$STATE_FILE"
      exit 0
    fi
    # Grade THIS session's most-recent question (plus any legacy untagged one).
    # If no session id is known, fall back to the global most-recent (LIFO).
    idx="$(jq --arg s "$sid" '
      (((.pending // []) | if type=="object" then [.] else . end))
      | [ to_entries[] | select(($s=="") or (.value.session==$s) or ((.value.session // "")=="")) | .key ]
      | (last // -1)' "$STATE_FILE")"
    [ "$idx" != "-1" ] || { echo "🤔 no pending question for you right now"; exit 0; }
    tgt="$(jq -c --argjson i "$idx" '(((.pending // []) | if type=="object" then [.] else . end))[$i]' "$STATE_FILE")"
    pa="$(printf '%s' "$tgt" | jq -r '.answer // empty')"
    pe="$(printf '%s' "$tgt" | jq -r '.explain // empty')"
    pq="$(printf '%s' "$tgt" | jq -r '.q // empty')"
    [ -n "$pq" ] && echo "Q: $pq"
    if [ "$(_norm "$u")" = "$(_norm "$pa")" ]; then
      _save --argjson i "$idx" '.pending = ((.pending // []) | if type=="object" then [.] else . end)
             | .quiz_count+=1 | .correct+=1 | .streak+=1 | .best_streak=([.best_streak,.streak]|max)
             | .pending = (.pending[:$i] + .pending[$i+1:])'
      echo "✅ correct!  (streak: $(jq -r .streak "$STATE_FILE"))"
    else
      _save --argjson i "$idx" '.pending = ((.pending // []) | if type=="object" then [.] else . end)
             | .quiz_count+=1 | .streak=0
             | .pending = (.pending[:$i] + .pending[$i+1:])'
      echo "❌ not quite — the answer was: $pa"
    fi
    [ -n "$pe" ] && echo "   💡 $pe"
    rem="$(jq --arg s "$sid" '(((.pending // []) | if type=="object" then [.] else . end))
           | map(select(($s=="") or (.session==$s) or ((.session // "")==""))) | length' "$STATE_FILE")"
    if [ "$rem" -gt 0 ]; then echo "   ($rem more open for you — answer the next with: cluo answer <ans>)"; fi
    ;;
  pending)
    sid="${CLAUDE_CODE_SESSION_ID:-}"
    if [ "${1:-}" = "clear" ]; then
      # Escape hatch for a cluttered backlog. Default clears YOUR session's open
      # questions plus the legacy untagged ones; --all wipes every session's.
      if [ "${2:-}" = "--all" ]; then
        _save '.pending = []'; echo "🧹 cleared all pending questions"
      else
        before="$(jq '(((.pending // []) | if type=="object" then [.] else . end)) | length' "$STATE_FILE")"
        _save --arg s "$sid" '.pending = (((.pending // []) | if type=="object" then [.] else . end)
               | map(select((.session // "") as $x | ($x != $s) and ($x != ""))))'
        after="$(jq '(.pending // []) | length' "$STATE_FILE")"
        echo "🧹 cleared $((before-after)) (your session + legacy untagged); $after still open in other sessions"
      fi
    elif [ "${1:-}" = "--all" ]; then
      # Cross-session audit: every open question, each tagged with its session's
      # last 4 chars so you can tell who asked what when many sessions run at once.
      jq -r '
        (((.pending // []) | if type=="object" then [.] else . end)) as $all
        | if ($all|length)==0 then "（nothing pending anywhere）"
          else "📋 all open questions (\($all|length)):",
               ($all | to_entries[]
                 | (.value.session // "") as $s
                 | (if ($s|length)>4 then $s[($s|length-4):] elif $s=="" then "----" else $s end) as $tag
                 | "   [\($tag)] \(.value.q // ("answer: "+.value.answer))")
          end' "$STATE_FILE"
    else
      jq -r --arg s "$sid" '
        (((.pending // []) | if type=="object" then [.] else . end)) as $all
        | ($all | map(select(($s=="") or (.session==$s) or ((.session // "")=="")))) as $mine
        | (if ($mine|length)==0 then "（no open questions for you — see all with: cluo pending --all）"
           else "📋 \(($mine|length)) open for you (newest last):",
                ($mine | to_entries[] | "   • \(.value.q // ("answer: "+.value.answer))") end),
          (if ($all|length) > ($mine|length) then "   (+\(($all|length)-($mine|length)) open in other sessions — cluo pending --all)" else empty end)
      ' "$STATE_FILE"
    fi
    ;;
  preset)
    case "${1:-}" in
      chill)    _save '.mode="chance" | .chance=20' ; echo "preset: chill (20% chance)" ;;
      normal)   _save '.mode="every"' ; echo "preset: normal (every task)" ;;
      hardcore) _save '.mode="every"' ; echo "preset: hardcore (every task)" ;;
      *) echo "usage: cluo preset chill|normal|hardcore"; exit 1 ;;
    esac
    ;;
  set)
    key="${1:-}"; val="${2:-}"
    case "$key" in
      mode)   case "$val" in every|freq|chance) _save --arg v "$val" '.mode=$v'; echo "mode: $val";; *) echo "mode must be every|freq|chance"; exit 1;; esac ;;
      freq)   _save --argjson v "$val" '.freq=$v'; echo "freq: $val" ;;
      chance) _save --argjson v "$val" '.chance=$v'; echo "chance: $val%" ;;
      *) echo "usage: cluo set mode|freq|chance <value>"; exit 1 ;;
    esac
    ;;
  reset)
    _save '.prompt_count=0 | .quiz_count=0 | .correct=0 | .streak=0 | .best_streak=0 | .words_seen=[] | .pending=[]'
    echo "scoreboard reset"
    ;;
  help|-h|--help)
    cat <<'USAGE'
cluo :: Cluolingo control + scoreboard CLI
Usage: cluo <command> [args]
  stats | state            show scoreboard
  on | off                 enable / disable the companion
  lang <language>          set the target practice language (e.g. cluo lang Japanese)
  native <language>        set your native language (default Chinese)
  ask <answer> [explain] [question]   queue a pending question (called by Claude)
  answer [text]            answer your most recent pending question; no text = peek what's open
  pending [--all]          list your open questions (--all = every session, tagged)
  pending clear [--all]    clear your session's open questions (--all = all sessions)
  grade correct|wrong      record an answer (called by Claude)
  word <text>              log a newly taught vocab item (called by Claude)
  preset chill|normal|hardcore
  set mode every|freq|chance
  set freq <N> | set chance <0-100>
  reset                    reset the scoreboard (keeps settings)
  help | -h | --help       show this help
USAGE
    ;;
  *) echo "cluo: unknown command '$cmd' (try: stats, on, off, lang, native, ask, answer, pending, grade, word, preset, set, reset, help)"; exit 1 ;;
esac
