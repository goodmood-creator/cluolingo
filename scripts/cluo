#!/usr/bin/env bash
# cluo :: Cluolingo control + scoreboard CLI
# Usage: cluo <command> [args]
#   stats                    show scoreboard
#   on | off                 enable / disable the companion
#   lang <language>          set the target practice language (e.g. cluo lang Japanese)
#   native <language>        set your native language (default Chinese)
#   grade correct|wrong      record an answer (called by Claude)
#   word <text>              log a newly taught vocab item (called by Claude)
#   preset chill|normal|hardcore
#   set mode every|freq|chance
#   set freq <N> | set chance <0-100>
#   reset                    reset the scoreboard (keeps settings)
set -euo pipefail

CONFIG_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
STATE_DIR="$CONFIG_DIR/cluolingo"
STATE_FILE="$STATE_DIR/state.json"

command -v jq >/dev/null 2>&1 || { echo "cluo: jq is required"; exit 1; }
mkdir -p "$STATE_DIR"
if [ ! -f "$STATE_FILE" ]; then
  cat > "$STATE_FILE" <<'JSON'
{ "enabled": true, "mode": "every", "freq": 5, "chance": 30,
  "target_lang": "English", "native_lang": "Chinese",
  "prompt_count": 0, "quiz_count": 0, "correct": 0,
  "streak": 0, "best_streak": 0, "pending": [], "words_seen": [] }
JSON
fi

_save() { # _save [jq-args...] '<filter>'  — all args forwarded to jq, then the state file
  local tmp; tmp="$(mktemp "$STATE_DIR/.state.XXXXXX")"
  jq "$@" "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

_norm() { # normalize an answer for comparison: lowercase, trim, strip surrounding punctuation
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//; s/^[^[:alnum:]]+//; s/[^[:alnum:]]+$//'
}

cmd="${1:-stats}"; shift || true
case "$cmd" in
  stats)
    jq -r '
      "🦉 Cluolingo — scoreboard",
      "  status   : \(if .enabled then "on" else "off" end)  (mode: \(.mode))",
      "  learning : \(.target_lang)  (from \(.native_lang))",
      "  asked    : \(.quiz_count)   correct: \(.correct)",
      "  accuracy : \(if .quiz_count>0 then ((.correct*100/.quiz_count)|floor|tostring)+"%" else "—" end)",
      "  streak   : \(.streak)   best: \(.best_streak)",
      "  words    : \(.words_seen|length) learned"
    ' "$STATE_FILE"
    ;;
  on)  _save '.enabled = true';  echo "cluolingo: on" ;;
  off) _save '.enabled = false'; echo "cluolingo: off" ;;
  lang)
    l="${*:-}"; [ -n "$l" ] || { echo "usage: cluo lang <language>  (e.g. cluo lang Japanese)"; exit 1; }
    _save --arg l "$l" '.target_lang = $l'
    echo "🎯 now practicing: $l"
    ;;
  native)
    l="${*:-}"; [ -n "$l" ] || { echo "usage: cluo native <language>"; exit 1; }
    _save --arg l "$l" '.native_lang = $l'
    echo "🏠 native language: $l"
    ;;
  grade)
    case "${1:-}" in
      correct) _save '.quiz_count+=1 | .correct+=1 | .streak+=1 | .best_streak = ([.best_streak,.streak]|max)'
               echo "✅ correct  (streak: $(jq -r .streak "$STATE_FILE"))" ;;
      wrong)   _save '.quiz_count+=1 | .streak = 0'
               echo "❌ wrong  (streak reset)" ;;
      *) echo "usage: cluo grade correct|wrong"; exit 1 ;;
    esac
    ;;
  word)
    w="${*:-}"; [ -n "$w" ] || { echo "usage: cluo word <text>"; exit 1; }
    _save --arg w "$w" '.words_seen = ((.words_seen + [$w]) | unique)'
    echo "📒 logged: $w"
    ;;
  ask)
    # Claude queues a pending question so the user can answer out-of-band.
    # pending is a QUEUE — multiple concurrent sessions/agents can each add one
    # without clobbering the others.
    a="${1:-}"; e="${2:-}"; q="${3:-}"
    [ -n "$a" ] || { echo "usage: cluo ask <correct_answer> [explanation] [question]"; exit 1; }
    _save --arg a "$a" --arg e "$e" --arg q "$q" '
      .pending = (((.pending // []) | if type=="object" then [.] else . end) + [{answer:$a, explain:$e, q:$q}])'
    n="$(jq '(.pending // []) | if type=="object" then 1 else length end' "$STATE_FILE")"
    echo "📌 question queued (#$n pending) — answer with:  btw answer <your answer>"
    ;;
  answer)
    u="${*:-}"; [ -n "$u" ] || { echo "usage: btw answer <your answer>"; exit 1; }
    # grade the MOST RECENT queued question (LIFO), then remove it
    last="$(jq -c '((.pending // []) | if type=="object" then [.] else . end) | last // empty' "$STATE_FILE")"
    [ -n "$last" ] || { echo "🤔 no pending question right now"; exit 0; }
    pa="$(printf '%s' "$last" | jq -r '.answer // empty')"
    pe="$(printf '%s' "$last" | jq -r '.explain // empty')"
    pq="$(printf '%s' "$last" | jq -r '.q // empty')"
    [ -n "$pq" ] && echo "Q: $pq"
    if [ "$(_norm "$u")" = "$(_norm "$pa")" ]; then
      _save '.pending = ((.pending // []) | if type=="object" then [.] else . end)
             | .quiz_count+=1 | .correct+=1 | .streak+=1 | .best_streak=([.best_streak,.streak]|max)
             | .pending = .pending[:-1]'
      echo "✅ correct!  (streak: $(jq -r .streak "$STATE_FILE"))"
    else
      _save '.pending = ((.pending // []) | if type=="object" then [.] else . end)
             | .quiz_count+=1 | .streak=0
             | .pending = .pending[:-1]'
      echo "❌ not quite — the answer was: $pa"
    fi
    [ -n "$pe" ] && echo "   💡 $pe"
    rem="$(jq '(.pending // []) | length' "$STATE_FILE")"
    [ "$rem" -gt 0 ] && echo "   ($rem more open — run: btw answer <ans> again)"
    ;;
  pending)
    jq -r '((.pending // []) | if type=="object" then [.] else . end) as $p
           | if ($p|length)==0 then "（no open questions）"
             else ($p | to_entries | reverse[] | "  [\(.key+1)] \(.value.q // ("answer: "+.value.answer))") end' "$STATE_FILE"
    ;;
  preset)
    case "${1:-}" in
      chill)    _save '.mode="chance" | .chance=20' ; echo "preset: chill (20% chance)" ;;
      normal)   _save '.mode="every"' ; echo "preset: normal (every task)" ;;
      hardcore) _save '.mode="every"' ; echo "preset: hardcore (every task)" ;;
      *) echo "usage: cluo preset chill|normal|hardcore"; exit 1 ;;
    esac
    ;;
  set)
    key="${1:-}"; val="${2:-}"
    case "$key" in
      mode)   case "$val" in every|freq|chance) _save --arg v "$val" '.mode=$v'; echo "mode: $val";; *) echo "mode must be every|freq|chance"; exit 1;; esac ;;
      freq)   _save --argjson v "$val" '.freq=$v'; echo "freq: $val" ;;
      chance) _save --argjson v "$val" '.chance=$v'; echo "chance: $val%" ;;
      *) echo "usage: cluo set mode|freq|chance <value>"; exit 1 ;;
    esac
    ;;
  reset)
    _save '.prompt_count=0 | .quiz_count=0 | .correct=0 | .streak=0 | .best_streak=0 | .words_seen=[] | .pending=[]'
    echo "scoreboard reset"
    ;;
  help|-h|--help)
    cat <<'USAGE'
cluo :: Cluolingo control + scoreboard CLI
Usage: cluo <command> [args]
  stats                    show scoreboard
  on | off                 enable / disable the companion
  lang <language>          set the target practice language (e.g. cluo lang Japanese)
  native <language>        set your native language (default Chinese)
  ask <answer> [explain] [question]   queue a pending question (called by Claude)
  answer <text>            answer the most recent pending question
  pending                  list open (unanswered) questions
  grade correct|wrong      record an answer (called by Claude)
  word <text>              log a newly taught vocab item (called by Claude)
  preset chill|normal|hardcore
  set mode every|freq|chance
  set freq <N> | set chance <0-100>
  reset                    reset the scoreboard (keeps settings)
  help | -h | --help       show this help
USAGE
    ;;
  *) echo "cluo: unknown command '$cmd' (try: stats, on, off, lang, native, ask, answer, pending, grade, word, preset, set, reset, help)"; exit 1 ;;
esac
